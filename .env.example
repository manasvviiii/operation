# Database connection string (Neon serverless Postgres)
# SECRET — do not commit real credentials
DATABASE_URL="postgresql://<user>:<password>@<host>/<dbname>?sslmode=require&channel_binding=require"

# Telegram Bot API token (from @BotFather)
# SECRET — do not commit real token
TELEGRAM_BOT_TOKEN="<your-telegram-bot-token>"

# Groq API key (for LLM planner agent and vision text extraction)
# SECRET — do not commit real key
GROQ_API_KEY="<your-groq-api-key>"

# Optional: override the Groq vision model used for image OCR
# Defaults to meta-llama/llama-4-scout-17b-16e-instruct if unset
# GROQ_VISION_MODEL="meta-llama/llama-4-scout-17b-16e-instruct"

# Vercel Blob storage credentials (for document uploads)
# SECRET — do not commit real credentials
BLOB_STORE_ID="<your-blob-store-id>"
BLOB_READ_WRITE_TOKEN="<your-vercel-blob-rw-token>"